 # ORQUESTRADOR PRINCIPAL — exposto ao sistema_manager como sa_run_audit
 # ================================================================
 
+SA_LOCK_FILE="/var/lock/security_audit.lock"
+SA_LOCK_FD=200
+
+# MELHORIA: evita que uma execução via cron (--security-fix semanal) e uma
+# execução manual simultânea (ex.: alguém no menu interativo) disputem o
+# gerenciador de pacotes ao mesmo tempo — apt/dpkg não tolera duas instâncias
+# concorrentes e o resultado pode ser um dpkg lock travado ou pior, um
+# pacote instalado pela metade.
+_sa_acquire_lock() {
+    mkdir -p "$(dirname "$SA_LOCK_FILE")" 2>/dev/null || true
+    eval "exec ${SA_LOCK_FD}>\"$SA_LOCK_FILE\"" 2>/dev/null || return 0
+    if ! flock -n "$SA_LOCK_FD"; then
+        _sa_log "ERROR" "Já existe uma auditoria de segurança em execução (lock: ${SA_LOCK_FILE}). Abortando para evitar concorrência no gerenciador de pacotes."
+        return 1
+    fi
+    return 0
+}
+
+_sa_release_lock() {
+    flock -u "$SA_LOCK_FD" 2>/dev/null || true
+    eval "exec ${SA_LOCK_FD}>&-" 2>/dev/null || true
+}
+
 sa_run_audit() {
     local dry_run="${1:-false}"
     local apply_fixes="${2:-false}"
 
+    if command -v flock >/dev/null 2>&1; then
+        _sa_acquire_lock || return 1
+        trap '_sa_release_lock; _sa_cleanup' EXIT
+    fi
+
     # Sincroniza SA_PKG do pai (PKG já foi definido por detect_package_manager)
     SA_PKG="${PKG:-unknown}"
     SA_DRY_RUN="$dry_run"

 _sa_cleanup() { rm -rf "$SA_TMP_DIR"; }
 trap _sa_cleanup EXIT
 
+# ------------------------------------------------------------------
+# MELHORIA: comparação exata de nome de pacote (não regex)
+# grep "^${pkg}\t" trata '.', '+', '*' etc. como metacaracteres — nomes
+# reais como "python3.11", "libssl1.1" ou "g++" podiam gerar falsos
+# positivos/negativos. awk com comparação de string ($1==p) é exato e
+# também evita o pipe extra grep|awk que existia em vários pontos.
+# ------------------------------------------------------------------
+_sa_installed_line() {
+    local pkg_name="$1"
+    awk -F'\t' -v p="$pkg_name" '$1==p{print; exit}' "${SA_TMP_DIR}/installed.txt" 2>/dev/null
+}
+
+_sa_installed_version() {
+    _sa_installed_line "$1" | awk -F'\t' '{print $2}'
+}
+
+_sa_is_installed() {
+    [ -n "$(_sa_installed_line "$1")" ]
+}
+
